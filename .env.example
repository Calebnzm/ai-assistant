# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.100.19,project.jarvis.local
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.100.19:5173
FRONTEND_URL=http://localhost:5173
# Set this to 1 only for local HTTP Google OAuth callback development.
# OAUTHLIB_INSECURE_TRANSPORT=1

# Database container/bootstrap values
POSTGRES_DB=aia_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Django database connection
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=aia_db
DATABASE_USER=postgres
DATABASE_PASSWORD=change-me
# In docker-compose.yml, DATABASE_HOST is overridden to db.
# DATABASE_URL=postgres://user:password@host:5432/dbname
# DATABASE_SSL_REQUIRE=False
# DATABASE_CONN_MAX_AGE=600

# OpenAI
OPENAI_API_KEY=change-me
OPENAI_MODEL=gpt-5.4-mini

# Google OAuth
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me

# Telegram
TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_BOT_USERNAME=change-me

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# In docker-compose.yml, Celery Redis URLs are overridden to redis://redis:6379/*.

# Frontend build
VITE_API_URL=http://127.0.0.1:8000/api
